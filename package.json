{
  "name": "specboards",
  "version": "0.21.0",
  "private": true,
  "description": "Lightweight, spec-based product management layer over git-native specs. Open-core self-host (AGPL-3.0) + hosted SaaS.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:up": "docker compose -f infra/docker-compose.yml up -d db",
    "db:migrate": "pnpm --filter @specboards/db migrate",
    "db:seed": "pnpm --filter @specboards/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "turbo": "^2.10.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "postcss": "8.5.16",
      "sharp": ">=0.35.0",
      "fast-uri": ">=3.1.4",
      "shell-quote": ">=1.9.0",
      "hono": ">=4.12.27",
      "body-parser": ">=2.3.0"
    },
    "patchedDependencies": {
      "sonner@2.0.7": "patches/sonner@2.0.7.patch"
    }
  }
}
