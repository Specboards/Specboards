# Copy to infra/.env (gitignored); docker compose reads it automatically.
#
# Required for any deployment other machines can reach. Set it BEFORE the
# first `docker compose up`: Postgres bakes the password into the data
# volume on initialization. Generate one with: openssl rand -hex 24
POSTGRES_PASSWORD=change-me

# Public origin of this deployment (scheme + host, no trailing slash). Used
# for OAuth callbacks and webhook URLs; required to be HTTPS when serving
# beyond localhost.
# APP_URL=https://specboards.example.com
